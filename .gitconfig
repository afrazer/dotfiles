[user]
    name = Alexander Frazer
    email = afrazer@protonmail.com

[alias]
    c = commit -m

    lg = log --color --graph --pretty=format:'%C(red)%h%C(reset) -%C(yellow)%d%C(reset) %s %C(green)(%cr) %C(bold blue)<%an> %C(reset)'

    l = "!source ~/.githelper && pretty_git_log"

    branches = for-each-ref --sort=-committerdate --format=\"%(color:blue)%(authordate:relative)\t%(color:red)%(authorname)\t%(color:white)%(color:bold)%(refname:short)\" refs/remotes

    graph = lg --decorate

    update = !git fetch --all --verbose --prune --tags

    upstream = !git reset --hard @{u}

    head = !git lg -n 20

    enforce = push --force-with-lease

    uncommit = reset --soft HEAD^

    new = lg main..

    missing = lg ..main

    oof = stash save --keep-index

    cena = commit --no-edit --amend

    root = rev-parse --show-toplevel

    mru = for-each-ref --sort=-committerdate --count=10 refs/heads/ --format='%(HEAD) %(color:yellow)%(refname:short)%(color:reset) - %(color:red)%(objectname:short)%(color:reset) - %(contents:subject) - %(authorname) (%(color:green)%(committerdate:relative)%(color:reset))'

[branch]
    sort = -committerdate
    autosetuprebase = always

[column]
    ui = auto

[commit]
    verbose = true

[core]
    pager = delta

[credential]
    helper = cache

[fetch]
    prune = true
    pruneTags = true
    all = true

[help]
    autocorrect = prompt

[init]
    defaultBranch = main

[tag]
    sort = version:refname

[merge]
    conflictStyle = zdiff3

[pull]
    rebase = true

[rebase]
    autoSquash = true
    autoStash = true
    updateRefs = true

[rerere]
    enabled = true
    autoupdate = true

[interactive]
    diffFilter = delta --color-only

[delta]
    navigate = true
    dark = true
    features = dracula line-numbers decorations
    line-numbers = true

[diff]
    algorithm = histogram
    colorMoved = zebra
    colorMovedWs = allow-indentation-change
    indentHeuristic = true
    mnemonicPrefix = true
    renames = true
    tool = nvimdiff

[difftool]
    prompt = false

[push]
    default = simple
    autoSetupRemote = true
    followTags = true

[status]
    showStash = true

[color "branch"]
    current = yellow bold
    local = green bold
    remote = cyan bold

[color "status"]
    added = green bold
    changed = yellow bold
    untracked = red bold

[delta "decorations"]
    minus-style = red bold normal
    plus-syle = gren bold normal
    minus-emph-style = white bold darkred
    minus-non-emph-style = red bold normal
    plus-emph-style = white bold darkgreen
    plus-non-emph-style = green bold normal
    file-style = yellow bold none
    file-decoration-style = yellow box
    hunk-header-style = magenta bold
    hunk-header-decoration-style = magenta box
    minus-empty-line-marker-style = normal normal
    plus-empty-line-marker-style = normal normal
    line-numbers-right-format = "{np:^4}| "

[delta "csv-clean"]
    word-diff-regex = "[%,]+"
    minus-style = syntax
    minus-word-style = bold red
    plus-style = syntax
    plus-word-style = bold green
    side-by-side = false
